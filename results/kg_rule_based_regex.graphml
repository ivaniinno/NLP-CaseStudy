      <data key="d1">travels_to</data>
      <data key="d2">1</data>
      <data key="d3">The Eye</data>
      <data key="d4">Accompanied by Paul, Sydney travels to Mexico, where the cornea donor Ana Cristina Martinez was originally from</data>
    </edge>
